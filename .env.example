# Access Infra — public site environment config
# Copy this file to ".env" (same folder) and fill in real values.
# ".env" is gitignored — never commit real credentials.

# Email address that receives Contact-form enquiries and is shown as the
# site's public contact address (footer, legal pages, etc.)
ADMIN_EMAIL=contact@accessinfraconsulting.com

# ── SendPulse (https://sendpulse.com) — used to deliver Contact form emails ──
# Get these from SendPulse: Account Settings → API → REST API.
# Required: an SMTP/email sending permission must be enabled on the API app.
SENDPULSE_CLIENT_ID=
SENDPULSE_CLIENT_SECRET=

# The "From" address/name used for outgoing mail. The sender address must be
# a verified domain/sender in your SendPulse account, or sending will fail.
SENDPULSE_SENDER_EMAIL=contact@accessinfraconsulting.com
SENDPULSE_SENDER_NAME=Access Infra Consulting
